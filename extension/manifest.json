{
  "manifest_version": 3,
  "name": "Commonplace",
  "version": "0.1.0",
  "description": "Save Claude and ChatGPT conversations to Commonplace as markdown wiki pages.",
  "permissions": ["storage", "downloads"],
  "host_permissions": [
    "https://claude.ai/*",
    "https://chatgpt.com/*",
    "https://api.commonplace.so/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*", "https://chatgpt.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html"
}
